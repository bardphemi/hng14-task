{
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/index.ts",
    "build": "tsc",
    "start": "node build/src/index.js",
    "test": "jest",
    "test:unit": "jest ----testPathPatterns /src/",
    "test:integration": "jest --testPathPatterns /tests/integration/",
    "migrate": "knex migrate:latest --knexfile ./knexfile.ts",
    "migrate:prod": "knex migrate:latest --env production --knexfile ./knexfile.ts",
    "rollback": "knex migrate:rollback --knexfile ./knexfile.ts",
    "rollback:prod": "knex migrate:rollback --env production --knexfile ./knexfile.ts",
    "prepare": "husky"
  },
  "dependencies": {
    "axios": "^1.15.0",
    "cors": "^2.8.6",
    "csv-parser": "^3.2.0",
    "dotenv": "^17.4.1",
    "express": "^5.2.1",
    "http-status": "^2.1.0",
    "husky": "^9.1.7",
    "joi": "^18.1.2",
    "knex": "^3.2.9",
    "mocha": "^11.7.5",
    "multer": "^2.1.1",
    "pg": "^8.20.0",
    "stream-chain": "^3.6.1",
    "stream-json": "^2.1.0",
    "uuid": "^13.0.0",
    "winston": "^3.19.0",
    "winston-daily-rotate-file": "^5.0.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/jest": "^30.0.0",
    "@types/mocha": "^10.0.10",
    "@types/multer": "^2.1.0",
    "@types/node": "^25.6.0",
    "@types/stream-json": "^1.7.8",
    "@types/supertest": "^6.0.3",
    "eslint": "^8.57.0",
    "jest": "^30.3.0",
    "nock": "^13.5.4",
    "prettier": "^3.8.2",
    "supertest": "^7.1.2",
    "ts-jest": "^29.2.5",
    "ts-node-dev": "^2.0.0",
    "typescript": "^6.0.2"
  }
}
